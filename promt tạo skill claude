PHẦN 4 — VÍ DỤ THAM KHẢO (output mong muốn)
═══════════════════════════════════════════

// auto/galxe.js
import { getCookie } from "../utils/loadCookies.js";
import { log, logResult } from "../utils/logger.js";

const PLATFORM = "galxe";
const BASE_URL = "https://app.galxe.com";

export async function run() {
  log(PLATFORM, "Bắt đầu check-in...");

  let cookie;
  try {
    cookie = getCookie(PLATFORM);
  } catch (err) {
    log(PLATFORM, err.message, "error");
    return { success: false, platform: PLATFORM };
  }

  const headers = {
    "accept": "application/json, text/plain, */*",
    "accept-language": "en-US,en;q=0.9",
    "content-type": "application/json",
    "cookie": cookie,
    "referer": `${BASE_URL}/dashboard`,
    "user-agent": "Mozilla/5.0 ...",
    "origin": BASE_URL,
  };

  try {
    // Bước 1: lấy token (nếu cần)
    log(PLATFORM, "Bước 1: lấy access token...");
    const tokenRes = await fetch(`${BASE_URL}/api/auth/token`, {
      method: "GET", headers,
    });
    if (tokenRes.status === 401) {
      logResult(PLATFORM, false, "Cookie hết hạn (401)");
      return { success: false, platform: PLATFORM, reason: "unauthorized" };
    }
    const { token } = await tokenRes.json();

    // Bước 2: check-in
    log(PLATFORM, "Bước 2: gọi check-in...");
    const res = await fetch(`${BASE_URL}/api/checkin`, {
      method: "POST",
      headers: { ...headers, "authorization": `Bearer ${token}` },
      body: JSON.stringify({ type: "daily" }),
    });
    const data = await res.json().catch(() => ({}));

    if (res.ok) {
      logResult(PLATFORM, true, data?.message || "OK");
      return { success: true, platform: PLATFORM, data };
    } else {
      logResult(PLATFORM, false, data?.message || res.status);
      return { success: false, platform: PLATFORM, reason: data?.message };
    }
  } catch (err) {
    log(PLATFORM, `Lỗi mạng: ${err.message}`, "error");
    return { success: false, platform: PLATFORM, reason: err.message };
  }
}

